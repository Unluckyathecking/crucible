# Crucible dashboard environment.
# `API_KEY_PREFIX` and `API_KEY_HASH_SALT` MUST match the gateway's values exactly —
# the dashboard issues keys; the gateway verifies them. Use a symlink to the repo root's
# .env or copy values manually.

# --- Postgres (same DB the gateway uses; schema is shared) ---
DATABASE_URL=postgres://crucible:crucible@localhost:5432/crucible

# --- API key parameters (MUST match the gateway) ---
API_KEY_PREFIX=cru_
API_KEY_HASH_SALT=REPLACE_WITH_32_PLUS_BYTES_OF_RANDOM_DATA__REPLACE_ME

# --- NextAuth ---
AUTH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
AUTH_URL=http://localhost:3000

# --- Redis (optional but recommended) ---
# Must point to the same Redis instance the gateway uses. When set, key revocation
# immediately clears the gateway's auth:{prefix} cache (CLAUDE.md invariant #7).
# Without this, revoked keys remain valid until the gateway's 60-second TTL expires.
# REDIS_URL=redis://localhost:6379/0

# --- Email (magic-link). If RESEND_API_KEY is unset, links are logged to stdout for dev. ---
# RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=Crucible <onboarding@crucible.local>

# --- Enterprise Edition license (Community edition needs none of this) ---
# CRUCIBLE_LICENSE_KEY: the offline Ed25519 license key (format cru1.<payload>.<sig>).
# Unset = Community edition; EE features (SSO, etc.) stay cleanly disabled.
# CRUCIBLE_LICENSE_KEY=cru1....
# CRUCIBLE_LICENSE_PUBKEY: hex Ed25519 public key that verifies the license.
# Leave unset to use the compiled-in default; set only if you minted your own keypair.
# Must match the gateway's CRUCIBLE_LICENSE_PUBKEY / license.DefaultPublicKeyHex.
# CRUCIBLE_LICENSE_PUBKEY=

# --- SSO (OIDC) — Enterprise Edition feature; requires a license granting `sso`. ---
# All three OIDC vars must be set AND the license must grant `sso` for the SSO
# button to appear; otherwise the login page is magic-link only (no change).
# SSO_OIDC_ISSUER=https://idp.example.com        # OIDC issuer URL (discovery must be reachable)
# SSO_OIDC_CLIENT_ID=your-client-id
# SSO_OIDC_CLIENT_SECRET=your-client-secret
# SSO_DISPLAY_NAME=Acme SSO                       # button label; defaults to "SSO"
