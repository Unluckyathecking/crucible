# Crucible dashboard environment.
# `API_KEY_PREFIX` and `API_KEY_HASH_SALT` MUST match the gateway's values exactly —
# the dashboard issues keys; the gateway verifies them. Use a symlink to the repo root's
# .env or copy values manually.

# --- Postgres (same DB the gateway uses; schema is shared) ---
DATABASE_URL=postgres://crucible:crucible@localhost:5432/crucible

# --- API key parameters (MUST match the gateway) ---
API_KEY_PREFIX=cru_
API_KEY_HASH_SALT=REPLACE_WITH_32_PLUS_BYTES_OF_RANDOM_DATA__REPLACE_ME

# --- NextAuth ---
AUTH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
AUTH_URL=http://localhost:3000
# Legacy alias for AUTH_URL; only needed on deployments still using the old NextAuth v4 name.
# NEXTAUTH_URL=http://localhost:3000

# --- Redis (optional but recommended) ---
# Must point to the same Redis instance the gateway uses. When set, key revocation
# immediately clears the gateway's auth:{prefix} cache (CLAUDE.md invariant #7).
# Without this, revoked keys remain valid until the gateway's 60-second TTL expires.
# REDIS_URL=redis://localhost:6379/0

# --- Email (magic-link). If RESEND_API_KEY is unset, links are logged to stdout for dev. ---
# RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=Crucible <onboarding@crucible.local>

# --- Stripe billing (checkout + billing-portal routes) ---
# Secret key (sk_...) the checkout and portal routes call the Stripe API with.
# STRIPE_SECRET_KEY=sk_REPLACE_ME
# Stripe price ID per upgradeable plan; checkout maps plan_id -> STRIPE_PRICE_<PLAN_ID_UPPER>.
# STRIPE_PRICE_PRO=price_REPLACE_ME
# STRIPE_PRICE_BUSINESS=price_REPLACE_ME

# --- Operator console (reads the gateway's /v1/admin/* endpoints) ---
# Base URL of the Crucible gateway. Defaults to http://localhost:8080 when unset.
# GATEWAY_URL=http://localhost:8080
# Static bearer token for the gateway's /v1/admin/* middleware; >= 32 bytes, must match the gateway.
# OPERATOR_TOKEN=REPLACE_WITH_32_PLUS_BYTES_OF_RANDOM_DATA
