{
  "title": "Crucible — Gateway Overview",
  "uid": "crucible-gateway",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(crucible_requests_total[1m])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 2,
      "title": "P95 latency (s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(crucible_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "p95 {{path}}" }
      ]
    },
    {
      "id": 3,
      "title": "Worker call latency (p50/p95/p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(crucible_worker_call_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(crucible_worker_call_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(crucible_worker_call_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 4,
      "title": "Usage records / s",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(crucible_usage_records_total[1m])", "legendFormat": "records/s" }
      ]
    },
    {
      "id": 5,
      "title": "Stripe billing flushes",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 },
      "targets": [
        { "expr": "sum by (outcome) (increase(crucible_billing_flush_total[1h]))", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "id": 6,
      "title": "Rate-limited requests",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 6 },
      "targets": [
        { "expr": "increase(crucible_rate_limited_total[1h])", "legendFormat": "last hour" }
      ]
    },
    {
      "id": 7,
      "title": "5xx error rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 6 },
      "targets": [
        { "expr": "sum(rate(crucible_requests_total{status=~\"5..\"}[1m]))", "legendFormat": "5xx/s" }
      ]
    },
    {
      "id": 8,
      "title": "Billing backlog — unflushed units",
      "description": "Current count of billable_units not yet emitted to Stripe. Updated each flusher tick. A rising value indicates a stalled flush pipeline.",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 22, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 1000000 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "crucible_billing_backlog_units", "legendFormat": "unflushed units" }
      ]
    },
    {
      "id": 9,
      "title": "Billing backlog — oldest row age",
      "description": "Age in seconds of the oldest unflushed usage_events row. Zero when the backlog is empty. Exceeding 900 s (15 min) triggers the BillingBacklogStale alert.",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 8, "y": 22, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 900 },
              { "color": "red", "value": 1800 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "crucible_billing_backlog_oldest_age_seconds", "legendFormat": "oldest age" }
      ]
    },
    {
      "id": 10,
      "title": "Permanently unbillable units",
      "description": "Unflushed billable_units for customers with no stripe_customer_id. These rows are silently excluded by the flush filter and represent a revenue leak. Should be zero in steady state.",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 16, "y": 22, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "crucible_billing_unbillable_units", "legendFormat": "unbillable units" }
      ]
    },
    {
      "id": 11,
      "title": "Async job completions (by outcome, 1h)",
      "description": "Count of async jobs that reached a terminal state in the last hour, broken down by outcome (succeeded or failed). Zero when AsyncRoutes is empty.",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 6 },
      "targets": [
        { "expr": "sum by (outcome) (increase(crucible_jobs_completed_total[1h]))", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "id": 12,
      "title": "Async job p95 execution duration",
      "description": "p95 wall time from claim to terminal state over the last 10 minutes. Exceeding 240 s (80% of the default JOB_TIMEOUT_MS of 300 s) triggers AsyncJobDurationSaturationHigh.",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 240 },
              { "color": "red", "value": 270 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(crucible_job_execution_duration_seconds_bucket[10m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 13,
      "title": "Async job failure ratio (5m)",
      "description": "Fraction of async job completions with outcome=failed over the last 5 minutes. Exceeding 10% triggers AsyncJobFailureRateElevated. Zero (or no data) when AsyncRoutes is empty.",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(crucible_jobs_completed_total{outcome=\"failed\"}[5m])) / sum(rate(crucible_jobs_completed_total[5m]))",
          "legendFormat": "failure ratio"
        }
      ]
    }
  ]
}
