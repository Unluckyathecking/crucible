# Crucible operational contract.
# Copy to `.env` and fill in values. `.env` is gitignored.

# --- Gateway HTTP ---
GATEWAY_PORT=8080
GATEWAY_BODY_LIMIT_BYTES=1048576

# --- Worker (where the gateway forwards Invoke() calls) ---
WORKER_URL=http://localhost:8081
# WORKER_TIMEOUT_MS: per-request HTTP deadline in milliseconds. Must be > 0.
WORKER_TIMEOUT_MS=10000
# GATEWAY_WORKER_MAX_CONNS caps total connections per worker host so a slow worker
# can't pin gateway sockets/goroutines without bound. Default: 64.
GATEWAY_WORKER_MAX_CONNS=64

# --- Worker resilience (retry + circuit-breaker) ---
# WORKER_RETRY_MAX: total call attempts including the first; 0 or 1 = single-shot (default).
#   Only connection/transport errors and HTTP 5xx are retried — HTTP 200 responses are NEVER
#   retried to prevent double-billing. Per-request timeouts (WORKER_TIMEOUT_MS exceeded) are
#   also NOT retried: a worker that timed out once is unlikely to respond faster on a retry.
#   Range: 0–10.
WORKER_RETRY_MAX=0
# WORKER_RETRY_BACKOFF_MS: base backoff in milliseconds before the first retry.
#   Actual wait uses equal jitter in [base/2, base], doubling each attempt up to an
#   internal ceiling of 5 s (not currently configurable via env).
WORKER_RETRY_BACKOFF_MS=100
# WORKER_BREAKER_THRESHOLD: consecutive failures before the breaker opens; 0 = disabled (default).
#   While open, calls fast-fail as WORKER_UNREACHABLE without hitting the worker.
#   Range when enabled: 1–100.
WORKER_BREAKER_THRESHOLD=0
# WORKER_BREAKER_COOLDOWN_MS: milliseconds the breaker stays open before allowing a probe.
#   Must be 0 (disabled/default) or >= 500 (any non-zero value below 500 causes rapid
#   open/half-open oscillation that wastes probe slots without giving the worker time to
#   recover). Must be <= 300000 (5 minutes). Valid non-zero range: 500–300000.
WORKER_BREAKER_COOLDOWN_MS=5000

# --- Postgres ---
# Define POSTGRES_PASSWORD BEFORE POSTGRES_DSN so shell consumers using `source .env`
# (e.g. scripts/seed-dev.sh) can resolve the interpolation. The gateway's main.go
# expands `${...}` placeholders in POSTGRES_DSN/REDIS_URL/WORKER_URL at startup so
# the same .env works for `docker compose up` (native ${VAR}) and `go run`.
#
# Password MUST be URL-safe — it's interpolated verbatim into the DSN above AND
# passed literally to the Postgres container as its server-side password. Anything
# that requires URL-encoding in one path desyncs the two (the container stores the
# literal "p%40ss" while the gateway's DSN parser decodes it back to "p@ss" → auth
# failure). Generate URL-safe with `openssl rand -hex 32` and avoid characters with
# URL meaning (@, :, /, ?, #, &, =, +, %, space) entirely.
POSTGRES_PASSWORD=REPLACE_WITH_HEX_OUTPUT_FROM_openssl_rand_hex_32
GF_ADMIN_PASSWORD=REPLACE_WITH_STRONG_GRAFANA_PASSWORD
POSTGRES_DSN=postgres://crucible:${POSTGRES_PASSWORD}@localhost:5432/crucible?sslmode=disable
POSTGRES_MAX_CONNS=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Stripe (test mode during the local build) ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_METER_NAME=crucible_units

# --- Security ---
API_KEY_PREFIX=cru_
# 32+ random bytes. Generate with:  openssl rand -base64 32
API_KEY_HASH_SALT=REPLACE_WITH_32_PLUS_BYTES_OF_RANDOM_DATA__REPLACE_ME

# --- Worker channel authentication ---
# WORKER_SHARED_SECRET: HMAC-SHA256 key shared between the gateway and every worker.
# When set, the gateway signs every /invoke request (X-Worker-Signature header) and
# each worker SDK verifies the signature before calling the handler. Unsigned or
# forged calls are rejected with UNAUTHORIZED (no billable_units charged).
# Leave unset (the default) to preserve today's behaviour — opt-in, zero-config-safe.
# The gateway and all workers that run against it MUST share the same value.
# Generate with:  openssl rand -hex 32
# WORKER_SHARED_SECRET=

# --- Error handling ---
# How worker-reported errors surface to customers.
#   sanitized (default) — stable error code + safe message only; internal worker
#                         detail (codes, messages) is never forwarded.
#   full                — forward the worker's error code + message verbatim.
#                         Opt-in only; do NOT use in production unless every worker
#                         is trusted to never emit sensitive detail in error text.
# Unset/empty is treated as the safe sanitized behaviour.
WORKER_ERROR_EXPOSURE=sanitized

# --- Async job multi-tenant fairness (see gateway/internal/jobs.Store.Claim) ---
# Both are opt-in; 0 (default) preserves today's unbounded global-FIFO claim
# and admission behaviour for every existing clone.
# JOB_MAX_INFLIGHT_PER_CUSTOMER: max jobs a single customer may have 'running'
#   at once across the shared worker pool. 0 = unbounded (default). When set,
#   must be <= JOB_WORKER_POOL_SIZE.
JOB_MAX_INFLIGHT_PER_CUSTOMER=0
# JOB_MAX_QUEUED_PER_CUSTOMER: ceiling on a customer's queued+running backlog;
#   POST /v1/<op> (async routes) returns 429 JOB_BACKLOG_EXCEEDED once reached.
#   0 = unbounded (default).
JOB_MAX_QUEUED_PER_CUSTOMER=0

# --- Observability ---
LOG_LEVEL=info
METRICS_PORT=9090
