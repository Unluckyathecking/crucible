# Crucible operational contract.
# Copy to `.env` and fill in values. `.env` is gitignored.

# --- Gateway HTTP ---
GATEWAY_PORT=8080
GATEWAY_BODY_LIMIT_BYTES=1048576

# --- Worker (where the gateway forwards Invoke() calls) ---
WORKER_URL=http://localhost:8081
# WORKER_TIMEOUT_MS: per-request HTTP deadline in milliseconds. Must be > 0.
WORKER_TIMEOUT_MS=10000
# GATEWAY_WORKER_MAX_CONNS caps total connections per worker host so a slow worker
# can't pin gateway sockets/goroutines without bound. Default: 64.
GATEWAY_WORKER_MAX_CONNS=64

# --- Worker resilience (retry + circuit-breaker) ---
# WORKER_RETRY_MAX: total call attempts including the first; 0 or 1 = single-shot (default).
#   Only connection/transport errors and HTTP 5xx are retried — HTTP 200 responses are NEVER
#   retried to prevent double-billing. Per-request timeouts (WORKER_TIMEOUT_MS exceeded) are
#   also NOT retried: a worker that timed out once is unlikely to respond faster on a retry.
#   Range: 0–10.
WORKER_RETRY_MAX=0
# WORKER_RETRY_BACKOFF_MS: base backoff in milliseconds before the first retry.
#   Actual wait uses equal jitter in [base/2, base], doubling each attempt up to an
#   internal ceiling of 5 s (not currently configurable via env).
WORKER_RETRY_BACKOFF_MS=100
# WORKER_BREAKER_THRESHOLD: consecutive failures before the breaker opens; 0 = disabled (default).
#   While open, calls fast-fail as WORKER_UNREACHABLE without hitting the worker.
#   Range when enabled: 1–100.
WORKER_BREAKER_THRESHOLD=0
# WORKER_BREAKER_COOLDOWN_MS: milliseconds the breaker stays open before allowing a probe.
#   Must be 0 (disabled/default) or >= 500 (any non-zero value below 500 causes rapid
#   open/half-open oscillation that wastes probe slots without giving the worker time to
#   recover). Must be <= 300000 (5 minutes). Valid non-zero range: 500–300000.
WORKER_BREAKER_COOLDOWN_MS=5000

# --- Postgres ---
# Define POSTGRES_PASSWORD BEFORE POSTGRES_DSN so shell consumers using `source .env`
# (e.g. scripts/seed-dev.sh) can resolve the interpolation. The gateway's main.go
# expands `${...}` placeholders in POSTGRES_DSN/REDIS_URL/WORKER_URL at startup so
# the same .env works for `docker compose up` (native ${VAR}) and `go run`.
#
# Password MUST be URL-safe — it's interpolated verbatim into the DSN above AND
# passed literally to the Postgres container as its server-side password. Anything
# that requires URL-encoding in one path desyncs the two (the container stores the
# literal "p%40ss" while the gateway's DSN parser decodes it back to "p@ss" → auth
# failure). Generate URL-safe with `openssl rand -hex 32` and avoid characters with
# URL meaning (@, :, /, ?, #, &, =, +, %, space) entirely.
POSTGRES_PASSWORD=REPLACE_WITH_HEX_OUTPUT_FROM_openssl_rand_hex_32
GF_ADMIN_PASSWORD=REPLACE_WITH_STRONG_GRAFANA_PASSWORD
POSTGRES_DSN=postgres://crucible:${POSTGRES_PASSWORD}@localhost:5432/crucible?sslmode=disable
POSTGRES_MAX_CONNS=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Stripe (test mode during the local build) ---
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_METER_NAME=crucible_units

# --- Self-serve billing (Stripe Checkout + Billing Portal) ---
# All three URLs must be set (together with STRIPE_SECRET_KEY) for the
# /v1/billing/checkout and /v1/billing/portal routes to activate; leaving any
# unset (the default) keeps those routes returning 503.
# CHECKOUT_SUCCESS_URL: where Stripe redirects after a completed checkout.
# CHECKOUT_SUCCESS_URL=https://app.example.com/billing/success
# CHECKOUT_CANCEL_URL: where Stripe redirects after a canceled checkout.
# CHECKOUT_CANCEL_URL=https://app.example.com/billing/cancel
# PORTAL_RETURN_URL: where the Billing Portal sends the customer on "Return".
# PORTAL_RETURN_URL=https://app.example.com/billing

# --- Security ---
API_KEY_PREFIX=cru_
# 32+ random bytes. Generate with:  openssl rand -base64 32
API_KEY_HASH_SALT=REPLACE_WITH_32_PLUS_BYTES_OF_RANDOM_DATA__REPLACE_ME
# OPERATOR_TOKEN gates /v1/admin/* routes. Empty (default) disables admin routes entirely.
# Must be >= 32 bytes when set. Generate with: openssl rand -hex 32
# OPERATOR_TOKEN=
# DASHBOARD_ORIGIN is the allowed CORS origin for dashboard API requests.
DASHBOARD_ORIGIN=http://localhost:3000

# --- Worker channel authentication ---
# WORKER_SHARED_SECRET: HMAC-SHA256 key shared between the gateway and every worker.
# When set, the gateway signs every /invoke request (X-Worker-Signature header) and
# each worker SDK verifies the signature before calling the handler. Unsigned or
# forged calls are rejected with UNAUTHORIZED (no billable_units charged).
# Leave unset (the default) to preserve today's behaviour — opt-in, zero-config-safe.
# The gateway and all workers that run against it MUST share the same value.
# Generate with:  openssl rand -hex 32
# WORKER_SHARED_SECRET=

# --- Error handling ---
# How worker-reported errors surface to customers.
#   sanitized (default) — stable error code + safe message only; internal worker
#                         detail (codes, messages) is never forwarded.
#   full                — forward the worker's error code + message verbatim.
#                         Opt-in only; do NOT use in production unless every worker
#                         is trusted to never emit sensitive detail in error text.
# Unset/empty is treated as the safe sanitized behaviour.
WORKER_ERROR_EXPOSURE=sanitized
# ERROR_PAYLOAD_CAPTURE: opt-in capture of request bodies on 4xx/5xx for debugging. Default off.
# ERROR_PAYLOAD_CAPTURE=false
# ERROR_PAYLOAD_MAX_BYTES: max captured body size in bytes (12–1048576). Only read when CAPTURE=true.
# ERROR_PAYLOAD_MAX_BYTES=4096

# --- Response result cache ---
# RESP_CACHE_MAX_TTL_SECONDS: ceiling TTL for per-route content-addressed response caching.
# Routes declare their own TTL (in routes_table.go); this caps it. Defaults to 1 hour.
RESP_CACHE_MAX_TTL_SECONDS=3600

# --- Async job execution (see gateway/internal/jobs) ---
# Inert until a route opts in via routes_table.go AsyncRoutes; these knobs have no effect
# for the default sync-only routing.
# JOB_WORKER_POOL_SIZE: goroutines polling and executing async jobs concurrently (1–256).
JOB_WORKER_POOL_SIZE=4
# JOB_POLL_INTERVAL_MS: delay between async_jobs poll cycles in milliseconds. Must be > 0.
JOB_POLL_INTERVAL_MS=1000
# JOB_TIMEOUT_MS: per-job execution deadline in milliseconds. Must be > 0.
JOB_TIMEOUT_MS=300000
# JOB_MAX_ATTEMPTS: max attempts for retryable (transport/5xx) job failures before dead-lettering.
JOB_MAX_ATTEMPTS=3
# JOB_RETRY_BACKOFF_MS: base backoff before first retry; doubles each attempt (1–60000 ms).
JOB_RETRY_BACKOFF_MS=2000
# JOB_RETENTION_DAYS: days to keep terminal (succeeded/failed) async_jobs rows; 0 disables reaper.
# JOB_RETENTION_DAYS=0
# JOB_REAPER_INTERVAL_MS: delay between async_jobs reaper sweeps in milliseconds.
# JOB_REAPER_INTERVAL_MS=3600000

# --- Async job multi-tenant fairness (see gateway/internal/jobs.Store.Claim) ---
# Both are opt-in; 0 (default) preserves today's unbounded global-FIFO claim
# and admission behaviour for every existing clone.
# JOB_MAX_INFLIGHT_PER_CUSTOMER: max jobs a single customer may have 'running'
#   at once across the shared worker pool. 0 = unbounded (default). When set,
#   must be <= JOB_WORKER_POOL_SIZE.
JOB_MAX_INFLIGHT_PER_CUSTOMER=0
# JOB_MAX_QUEUED_PER_CUSTOMER: ceiling on a customer's queued+running backlog;
#   POST /v1/<op> (async routes) returns 429 JOB_BACKLOG_EXCEEDED once reached.
#   0 = unbounded (default).
JOB_MAX_QUEUED_PER_CUSTOMER=0

# --- Webhook delivery multi-tenant fairness (see gateway/internal/webhookout.Emitter.claimDue) ---
# Opt-in; 0 (default) preserves today's unbounded global-FIFO claim behaviour
# for every existing clone.
# WEBHOOK_MAX_INFLIGHT_PER_CUSTOMER: max webhook_deliveries rows a single
#   customer may have 'delivering' at once across the shared delivery worker.
#   0 = unbounded (default).
WEBHOOK_MAX_INFLIGHT_PER_CUSTOMER=0

# --- Retention reapers ---
# All retention knobs default to 0 (disabled / inert). Set to a positive number
# of days to enable the background reaper for that table.  The interval controls
# how often the reaper runs (milliseconds; default 1 hour).
#
# idempotency_keys — rows grow without bound at high request volume because the
# Store only deletes lazily on re-query of the same key; almost no key is ever
# re-queried.
# IDEMPOTENCY_RETENTION_DAYS=30
# IDEMPOTENCY_REAPER_INTERVAL_MS=3600000
#
# webhook_deliveries — only status='delivered' rows are deleted; dead_letter
# rows are never touched (operators replay those via the dead-letter console).
# WEBHOOK_DELIVERY_RETENTION_DAYS=30
# WEBHOOK_DELIVERY_REAPER_INTERVAL_MS=3600000

# --- Observability ---
LOG_LEVEL=info
METRICS_PORT=9090

# --- Tracing (OTel) ---
# OTEL_TRACING_ENABLED=false dials no exporter and adds zero overhead; set true to enable.
OTEL_TRACING_ENABLED=false
# OTEL_EXPORTER_ENDPOINT: OTLP gRPC exporter host:port without scheme (e.g. localhost:4317).
# Required when OTEL_TRACING_ENABLED=true.
# OTEL_EXPORTER_ENDPOINT=
# OTEL_EXPORTER_INSECURE: disable TLS for the OTLP exporter. Set true for localhost/sidecar collectors.
OTEL_EXPORTER_INSECURE=false
# OTEL_SAMPLE_RATIO: fraction of traces to sample [0.0, 1.0]; 1.0 = sample all (default).
OTEL_SAMPLE_RATIO=1.0

# --- Reverse proxy / TLS (read by docker-compose.yml + Caddyfile, not the gateway) ---
# DOMAIN: public hostname Caddy serves and reverse-proxies to the gateway.
#   Defaults to localhost (self-signed HTTPS for local/dev). Set to your domain
#   in production, e.g. api.example.com.
# DOMAIN=
# TLS_POLICY: Caddy's tls directive. Defaults to 'internal' (self-signed cert).
#   Leave empty in production for Let's Encrypt certificates via ACME.
# TLS_POLICY=
